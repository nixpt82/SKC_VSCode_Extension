{
  "servers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {
        "PLAYWRIGHT_BROWSER": "msedge"
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "<CONTEXT7_API_KEY>"
      }
    },
    "MS Learn Docs": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp",
      "headers": {}
    },
    "bc-intelligence": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "bc-code-intelligence-mcp"
      ]
    },
    "bc-mcp-proxy": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "bc-mcp-proxy-fisqal"
      ],
      "env": {
        "BC_TENANT_ID": "<YOUR_TENANT_ID_OR_DOMAIN>",
        "BC_CLIENT_ID": "<YOUR_AZURE_AD_APP_CLIENT_ID>",
        "BC_ENVIRONMENT": "Production",
        "BC_COMPANY": "<YOUR_BC_COMPANY_NAME>",
        "BC_CONFIG_NAME": ""
      }
    },
    "mcp-pandoc": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-pandoc"
      ]
    },
    "microsoft/markitdown": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "markitdown-mcp@0.0.1a4"
      ]
    }
  },
  "inputs": [
    {
      "id": "githubToken",
      "type": "promptString",
      "description": "GitHub Personal Access Token for MCP server",
      "password": true
    }
  ]
}